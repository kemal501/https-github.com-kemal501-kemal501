rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAgent() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'agent';
    }
    function isHost() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'host';
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'kemalziyad4@gmail.com' || (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        )
      );
    }

    // User profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && 
        request.resource.data.keys().hasAll(['displayName', 'coins', 'role', 'createdAt']) &&
        request.resource.data.coins == 1000 && // Starter coins
        request.resource.data.role == 'user';
      allow update: if (isOwner(userId) && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'displayName', 'photoURL', 'bio', 'category', 'isFaceVerified', 
          'faceVerifiedAt', 'agencyId', 'role', 'following', 'coins', 
          'paymentMethod', 'verificationRequest', 'minutesInRoomToday', 'lastHeatbeatDate',
          'loginStreak', 'lastStreakClaimedDate'
        ])
      )) || (
        // Allow others to only increment the user's coins (for gifting)
        isSignedIn() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['coins']) &&
        request.resource.data.coins > resource.data.coins
      ) || isAdmin();
    }

    // Following lists
    match /users/{userId}/following/{followingId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // Agencies
    match /agencies/{agencyId} {
      allow read: if isSignedIn();
      allow create: if isAgent();
      allow update: if isAgent() && resource.data.ownerId == request.auth.uid;
    }

    // Rooms
    match /rooms/{roomId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn(); // Broad for now, usually restricted to host or moderator
      allow delete: if isSignedIn() && resource.data.hostId == request.auth.uid;

      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && 
          (request.resource.data.senderId == request.auth.uid || request.resource.data.senderId == 'system') &&
          request.resource.data.text.size() <= 500;
        allow delete: if isSignedIn() && (
          request.auth.uid == resource.data.senderId ||
          request.auth.uid == get(/databases/$(database)/documents/rooms/$(roomId)).data.hostId
        );
      }
    }

    // Withdrawals
    match /withdrawals/{withdrawalId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // Tasks
    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow create: if isAgent();
      allow update: if isSignedIn(); // Allow hosts to start/progress tasks
    }

    // Task completions
    match /users/{userId}/task_completions/{taskId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
    }

    // Global Coin Transactions
    match /coin_transactions/{transactionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }

    // Transactions
    match /users/{userId}/transactions/{transactionId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) || (isSignedIn() && request.resource.data.toId == userId && request.resource.data.type == 'gift');
    }

    // Blocked users
    match /users/{userId}/blocked/{blockedId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // Sitting rewards
    match /users/{userId}/sitting_rewards/{sittingId} {
      allow read, write: if isOwner(userId);
    }

    // Saved recordings in Cloud Storage indexed via Firestore
    match /users/{userId}/recordings/{recordingId} {
      allow read, write: if isOwner(userId);
    }

    // Global Music Broadcast Synchronization
    match /global_music/{musicId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(musicId);
    }

    // Role change audits
    match /role_change_audits/{auditId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }
  }
}
