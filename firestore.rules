rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function getUserData() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function isAgent() { return isSignedIn() && getUserData().role == 'agent'; }
    function isHost() { return isSignedIn() && getUserData().role == 'host'; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // User profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && 
        request.resource.data.keys().hasAll(['displayName', 'coins', 'role', 'createdAt']) &&
        request.resource.data.coins == 1000 && // Starter coins
        request.resource.data.role == 'user';
      allow update: if isOwner(userId) && (
        // Allow updating profile info
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL', 'bio', 'category', 'isFaceVerified', 'faceVerifiedAt', 'agencyId', 'role']) ||
        // Allow updating coins (only through controlled transactions - bit complex here, ideally backend handles coins)
        // For this app, we'll allow client to decrement their coins for gifts and increment for rewards
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['coins'])
      );
    }

    // Agencies
    match /agencies/{agencyId} {
      allow read: if isSignedIn();
      allow create: if isAgent();
      allow update: if isAgent() && resource.data.ownerId == request.auth.uid;
    }

    // Rooms
    match /rooms/{roomId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn(); // Broad for now, usually restricted to host or moderator
      allow delete: if isSignedIn() && resource.data.hostId == request.auth.uid;

      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && 
          request.resource.data.senderId == request.auth.uid &&
          request.resource.data.text.size() <= 500;
        allow delete: if isSignedIn() && (
          request.auth.uid == resource.data.senderId ||
          request.auth.uid == get(/databases/$(database)/documents/rooms/$(roomId)).data.hostId
        );
      }
    }

    // Tasks
    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow create: if isAgent();
      allow update: if isSignedIn(); // Allow hosts to start/progress tasks
    }

    // Task completions
    match /users/{userId}/task_completions/{taskId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
    }

    // Transactions
    match /users/{userId}/transactions/{transactionId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
    }
  }
}
