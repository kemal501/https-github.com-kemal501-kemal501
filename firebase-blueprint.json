{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and balance information.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "email": { "type": "string" },
        "coins": { "type": "number" },
        "isVerified": { "type": "boolean" },
        "isFaceVerified": { "type": "boolean" },
        "faceVerifiedAt": { "type": "string", "format": "date-time" },
        "agencyId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "host", "agent"] },
        "bio": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["displayName", "coins", "role"]
    },
    "Room": {
      "title": "Room",
      "description": "Voice/Video chat room data and settings.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "hostId": { "type": "string" },
        "hostName": { "type": "string" },
        "type": { "type": "string", "enum": ["voice", "video"] },
        "status": { "type": "string", "enum": ["live", "ended"] },
        "viewerCount": { "type": "number" },
        "seats": { "type": "array" },
        "settings": { "type": "object" },
        "bannedUsers": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "hostId", "hostName", "type", "status"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat messages within a room.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "senderName", "text", "createdAt"]
    },
    "Task": {
      "title": "Task",
      "description": "Agency or system tasks for hosts.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "reward": { "type": "number" },
        "rewardType": { "type": "string", "enum": ["coins", "usd"] },
        "deadline": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["available", "in-progress", "completed"] },
        "assignedTo": { "type": "string" },
        "agencyId": { "type": "string" },
        "creatorId": { "type": "string" },
        "progress": { "type": "number" },
        "target": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "reward", "rewardType", "status", "creatorId"]
    },
    "TaskCompletion": {
      "title": "Task Completion",
      "description": "Records of users completing tasks.",
      "type": "object",
      "properties": {
        "taskId": { "type": "string" },
        "userId": { "type": "string" },
        "rewardClaimed": { "type": "number" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["taskId", "userId", "rewardClaimed", "completedAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Coin transactions (gifts, rewards).",
      "type": "object",
      "properties": {
        "fromId": { "type": "string" },
        "toId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["gift", "reward", "purchase"] },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["amount", "type", "status", "createdAt"]
    },
    "Agency": {
      "title": "Agency",
      "description": "Broadcasting agency information.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "ownerId": { "type": "string" },
        "tier": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile data."
    },
    "users/{userId}/task_completions/{taskId}": {
      "schema": "TaskCompletion",
      "description": "Users task completion records."
    },
    "users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Users transaction history."
    },
    "rooms/{roomId}": {
      "schema": "Room",
      "description": "Live room data."
    },
    "rooms/{roomId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Room chat messages."
    },
    "tasks/{taskId}": {
      "schema": "Task",
      "description": "Global or agency-specific tasks."
    },
    "agencies/{agencyId}": {
      "schema": "Agency",
      "description": "Agency details."
    }
  }
}
